# =============================================================================
# Observability environment variables (Sentry)
# =============================================================================
# Copy this file to .env (or your runtime env manager) and fill the values
# AFTER creating a Sentry project at https://sentry.io.
#
# Both DSNs are project-scoped: one for the Django backend, one for the
# React frontend. Keeping them split lets you triage errors per layer
# and apply different sampling rates.
# =============================================================================

# --- Backend (Django) --------------------------------------------------------
# Get from Sentry web UI: Settings > Projects > <backend-project> > SDK Setup
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
# Set in CI to the git commit SHA so post-mortems can correlate to deploys
SENTRY_RELEASE=
# 0.0 = no traces. Raise temporarily (e.g. 0.1) when investigating latency.
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Frontend (Vite / React) -------------------------------------------------
# Get from Sentry web UI: Settings > Projects > <frontend-project> > SDK Setup
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=staging
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0

# =============================================================================
# Setup checklist (do once per environment)
# =============================================================================
# 1. Create Sentry account (free plan): https://sentry.io/signup/
# 2. Create two projects: "labionexus-backend" (Django) and
#    "labionexus-frontend" (React).
# 3. Copy each project's DSN into the variables above.
# 4. Configure alert rules in the Sentry web UI per severity tag:
#       severity:p0  -> immediate email + SMS (when SMS available)
#       severity:p1  -> email within 5 minutes
#       severity:p2  -> daily digest
#       severity:p3  -> weekly digest
# 5. Wire your CI to set SENTRY_RELEASE / VITE_SENTRY_RELEASE to the
#    deploying commit SHA for release-based change tracking.
# =============================================================================
