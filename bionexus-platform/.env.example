# BioNexus environment configuration (template).
# Copy to `.env` (not tracked) and fill in real values.

# --- Database (optional override; falls back to SQLite in dev) ---
# DATABASE_URL=postgres://bionexus:bionexus@db:5432/bionexus

# --- Sentry (optional; only initialized when set) ---
# SENTRY_DSN=

# ===========================================================================
# LIMS / QMS / ELN integration suite
# ===========================================================================
# Every connector follows the same pattern:
#   <VENDOR>_MODE                  : disabled (default, prod-safe) | mock | sandbox | prod
#   <VENDOR>_INTEGRATION_ENABLED   : "true" to wire post_save(Measurement) -> push
#   <VENDOR>_BASE_URL              : target host
#   <VENDOR>_SHARED_SECRET         : HMAC signing secret (generate with python -c 'import secrets; print(secrets.token_urlsafe(48))')
#   <VENDOR>_PROD_CONFIRMED        : env-only "true" gates prod mode (anti-foot-gun)

# --- Mock server (when MODE=mock for any vendor) ---
# Default: a single mock server on :8001 serves every vendor's flavour:
#   /veeva/...      /empower/...      /labware/...      /starlims/...      /benchling/...
# Start it with: python manage.py lims_mock_server
LIMS_MOCK_FAIL_RATE=0
# LIMS_MOCK_STATE_DIR=./lims_mock_state   # where the mock persists received objects

# ---------------------------------------------------------------------------
# Veeva Vault QMS (LBN-INT-VEEVA-001)
# ---------------------------------------------------------------------------
VEEVA_MODE=disabled
VEEVA_INTEGRATION_ENABLED=false
VEEVA_BASE_URL=
VEEVA_SHARED_SECRET=
VEEVA_SESSION_TOKEN=

# ---------------------------------------------------------------------------
# Waters Empower (CDS, HPLC/UPLC)
# ---------------------------------------------------------------------------
EMPOWER_MODE=disabled
EMPOWER_INTEGRATION_ENABLED=false
EMPOWER_BASE_URL=
EMPOWER_SHARED_SECRET=
EMPOWER_API_KEY=

# ---------------------------------------------------------------------------
# LabWare LIMS
# ---------------------------------------------------------------------------
LABWARE_MODE=disabled
LABWARE_INTEGRATION_ENABLED=false
LABWARE_BASE_URL=
LABWARE_SHARED_SECRET=
LABWARE_API_KEY=

# ---------------------------------------------------------------------------
# STARLIMS
# ---------------------------------------------------------------------------
STARLIMS_MODE=disabled
STARLIMS_INTEGRATION_ENABLED=false
STARLIMS_BASE_URL=
STARLIMS_SHARED_SECRET=
STARLIMS_API_KEY=

# ---------------------------------------------------------------------------
# Benchling ELN
# ---------------------------------------------------------------------------
BENCHLING_MODE=disabled
BENCHLING_INTEGRATION_ENABLED=false
BENCHLING_BASE_URL=
BENCHLING_SHARED_SECRET=
BENCHLING_API_TOKEN=
BENCHLING_RESULT_SCHEMA_ID=sch_bnx_default
